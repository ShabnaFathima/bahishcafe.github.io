<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bahish Cafe</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f8f5f0;
color:#333;
}

header{
background:#3b2a20;
padding:15px;
position:sticky;
top:0;
z-index:100;
}

nav{
display:flex;
justify-content:center;
gap:25px;
}

nav a{
color:white;
text-decoration:none;
font-weight:bold;
}

.hero{
height:80vh;
background:url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?q=80&w=1200') center/cover;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
}

.hero-content{
background:rgba(0,0,0,0.6);
padding:30px;
border-radius:10px;
color:white;
}

.hero h1{
font-size:48px;
margin-bottom:15px;
}

.hero p{
font-size:18px;
}

.section{
padding:50px 20px;
max-width:1100px;
margin:auto;
}

.section h2{
text-align:center;
margin-bottom:30px;
color:#5b3d2e;
}

.menu-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.menu-item{
background:white;
padding:20px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,.1);
}

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:15px;
}

.gallery img{
width:100%;
height:220px;
object-fit:cover;
border-radius:10px;
}

.contact{
background:white;
padding:25px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,.1);
}

.whatsapp{
position:fixed;
right:20px;
bottom:20px;
background:#25D366;
color:white;
padding:15px 20px;
border-radius:50px;
text-decoration:none;
font-weight:bold;
}

footer{
background:#3b2a20;
color:white;
text-align:center;
padding:20px;
margin-top:40px;
}

iframe{
width:100%;
height:350px;
border:none;
border-radius:10px;
}

</style>
</head>

<body>

<header>
<nav>
<a href="#home">Home</a>
<a href="#menu">Menu</a>
<a href="#gallery">Gallery</a>
<a href="#contact">Contact</a>
</nav>
</header>

<section class="hero" id="home">
<div class="hero-content">
<h1>Bahish Cafe</h1>
<p>Fresh Coffee • Delicious Food • Great Moments</p>
</div>
</section>

<section class="section">
<h2>About Us</h2>
<p style="text-align:center;">
Welcome to Bahish Cafe. We serve premium coffee, delicious snacks and
fresh meals in a cozy atmosphere. Whether you are meeting friends,
working remotely or enjoying family time, Bahish Cafe is the perfect destination.
</p>
</section>

<section class="section" id="menu">
<h2>Popular Menu</h2>

<div class="menu-grid">

<div class="menu-item">
<h3>Cappuccino</h3>
<p>AED 15</p>
</div>

<div class="menu-item">
<h3>Latte</h3>
<p>AED 16</p>
</div>

<div class="menu-item">
<h3>Club Sandwich</h3>
<p>AED 22</p>
</div>

<div class="menu-item">
<h3>French Fries</h3>
<p>AED 12</p>
</div>

<div class="menu-item">
<h3>Chocolate Cake</h3>
<p>AED 18</p>
</div>

<div class="menu-item">
<h3>Fresh Mojito</h3>
<p>AED 14</p>
</div>

</div>
</section>

<section class="section" id="gallery">
<h2>Gallery</h2>

<div class="gallery">

<img src="https://images.unsplash.com/photo-1509042239860-f550ce710b93">
<img src="https://images.unsplash.com/photo-1445116572660-236099ec97a0">
<img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4">
<img src="https://images.unsplash.com/photo-1554118811-1e0d58224f24">

</div>
</section>

<section class="section">
<h2>Location</h2>

<iframe
src="https://maps.google.com/maps?q=Dubai,UAE&t=&z=13&ie=UTF8&iwloc=&output=embed">
</iframe>

</section>

<section class="section" id="contact">

<h2>Contact Us</h2>

<div class="contact">

<p><strong>Phone:</strong> 123456789</p>

<p><strong>Address:</strong> ABC, Dubai, UAE</p>

<p><strong>Email:</strong> info@bahishcafe.com</p>

</div>

</section>

